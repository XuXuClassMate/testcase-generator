# Standalone mode environment variables

# Primary model selection for env-based startup fallback.
# Supported: anthropic, openai, deepseek
AI_PROVIDER=anthropic

# API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# Runtime
LANGUAGE=en
ENABLE_REVIEW=true
REVIEW_THRESHOLD=90
MAX_REVIEW_ROUNDS=5
PORT=3456
OUTPUT_DIR=./testcase-output
